<?xml version="1.0" encoding="UTF-8"?>

<!--
═══════════════════════════════════════════════════════════
 dialogo-posicao.fxml — Pop-up de entrada de coordenada
 Controller: controller.DialogoPosicaoController

 QUANDO USAR:
 Este FXML é uma alternativa visual ao TextInputDialog
 do EntradaDados.java — uma janela modal personalizada
 que mantém o visual do jogo (tema escuro, Courier New)
 em vez de usar o diálogo padrão do sistema operacional.

 CONCEITO: Stage modal
 Um "diálogo modal" é uma janela que bloqueia a janela
 principal enquanto está aberta — o usuário precisa
 interagir com ela antes de voltar ao jogo.
 No JavaFX isso é feito com:
   stage.initModality(Modality.APPLICATION_MODAL)
 no DialogoPosicaoController.

 LAYOUT: VBox simples com dois campos (X e Y) e
 dois botões (Confirmar / Cancelar).

 COMO ABRIR ESTE DIÁLOGO DO JOGOCONTROLLER:
   FXMLLoader loader = new FXMLLoader(
       getClass().getResource("/fxml/dialogo-posicao.fxml")
   );
   Parent raiz = loader.load();
   DialogoPosicaoController ctrl = loader.getController();
   ctrl.setTitulo("Posição do Alimento");

   Stage dialogo = new Stage();
   dialogo.initModality(Modality.APPLICATION_MODAL);
   dialogo.setScene(new Scene(raiz));
   dialogo.showAndWait();  // bloqueia até fechar

   int[] resultado = ctrl.getResultado();
   // resultado == null → usuário cancelou
   // resultado[0] = x, resultado[1] = y
═══════════════════════════════════════════════════════════
-->

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.DialogoPosicaoController"
    alignment="TOP_CENTER"
    spacing="0"
    prefWidth="300"
    style="-fx-background-color: #0D0D22;">

    <!-- Faixa de acento no topo -->
    <Rectangle width="300" height="2"
        style="-fx-fill: linear-gradient(to right, #0D0D22, #4A90D9, #0D0D22);"/>

    <!-- ── Cabeçalho ── -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-padding: 20 24 16 24;">

        <!-- Título dinâmico — alterado pelo DialogoPosicaoController -->
        <Label fx:id="labelTitulo"
               text="INSERIR POSIÇÃO"
               style="-fx-font-family: 'Courier New';
                      -fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #A0A0D0;
                      -fx-letter-spacing: 2px;"/>

        <Label fx:id="labelSubtitulo"
               text="coordenadas válidas: 0 a 3"
               style="-fx-font-family: 'Courier New';
                      -fx-font-size: 10px;
                      -fx-text-fill: #2A2A55;"/>
    </VBox>

    <Separator style="-fx-background-color: #1A1A40;"/>

    <!-- ── Campos de entrada ── -->
    <!--
        TextField: campo de texto de linha única.
        fx:id permite o Controller ler o valor com
        campoX.getText() e validar se é número válido.

        promptText: texto cinza que aparece quando
        o campo está vazio — orienta o usuário.
        Desaparece automaticamente ao digitar.
    -->
    <VBox spacing="14" style="-fx-padding: 20 24 20 24;">

        <!-- Campo X -->
        <VBox spacing="6">
            <Label text="EIXO  X"
                   style="-fx-font-family: 'Courier New';
                          -fx-font-size: 10px;
                          -fx-text-fill: #3A3A70;
                          -fx-letter-spacing: 2px;"/>
            <TextField
                fx:id="campoX"
                promptText="0, 1, 2 ou 3"
                style="-fx-background-color: #080818;
                       -fx-border-color: #2A2A55;
                       -fx-border-width: 1;
                       -fx-border-radius: 4;
                       -fx-background-radius: 4;
                       -fx-text-fill: #90CAF9;
                       -fx-prompt-text-fill: #252545;
                       -fx-font-family: 'Courier New';
                       -fx-font-size: 16px;
                       -fx-padding: 10 14;"/>
        </VBox>

        <!-- Campo Y -->
        <VBox spacing="6">
            <Label text="EIXO  Y"
                   style="-fx-font-family: 'Courier New';
                          -fx-font-size: 10px;
                          -fx-text-fill: #3A3A70;
                          -fx-letter-spacing: 2px;"/>
            <TextField
                fx:id="campoY"
                promptText="0, 1, 2 ou 3"
                style="-fx-background-color: #080818;
                       -fx-border-color: #2A2A55;
                       -fx-border-width: 1;
                       -fx-border-radius: 4;
                       -fx-background-radius: 4;
                       -fx-text-fill: #90CAF9;
                       -fx-prompt-text-fill: #252545;
                       -fx-font-family: 'Courier New';
                       -fx-font-size: 16px;
                       -fx-padding: 10 14;"/>
        </VBox>

        <!-- Mensagem de erro — visível só quando há entrada inválida -->
        <!--
            visible="false" → oculto por padrão.
            O DialogoPosicaoController faz
            labelErro.setVisible(true) se o usuário
            digitar algo que não seja 0-3.
        -->
        <Label fx:id="labelErro"
               text="⚠  Digite um número entre 0 e 3"
               visible="false"
               style="-fx-font-family: 'Courier New';
                      -fx-font-size: 11px;
                      -fx-text-fill: #EF5350;"/>
    </VBox>

    <Separator style="-fx-background-color: #1A1A40;"/>

    <!-- ── Botões de ação ── -->
    <!--
        Dois botões lado a lado com larguras iguais (50%).
        Cancelar → chama onCancelar() → resultado = null
        Confirmar → chama onConfirmar() → valida e fecha
    -->
    <HBox spacing="0" style="-fx-padding: 0;">

        <Button text="CANCELAR"
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"
                onAction="#onCancelar"
                style="-fx-background-color: #0D0D22;
                       -fx-border-color: transparent;
                       -fx-border-width: 0;
                       -fx-text-fill: #4A4A7A;
                       -fx-font-family: 'Courier New';
                       -fx-font-size: 12px;
                       -fx-cursor: hand;
                       -fx-padding: 14 0;"/>

        <!-- Linha divisória vertical entre os botões -->
        <Rectangle width="1" height="46"
            style="-fx-fill: #1A1A40;"/>

        <Button text="CONFIRMAR"
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"
                onAction="#onConfirmar"
                defaultButton="true"
                style="-fx-background-color: #0D1F3C;
                       -fx-border-color: transparent;
                       -fx-border-width: 0;
                       -fx-text-fill: #90CAF9;
                       -fx-font-family: 'Courier New';
                       -fx-font-size: 12px;
                       -fx-font-weight: bold;
                       -fx-cursor: hand;
                       -fx-padding: 14 0;"/>
    </HBox>

</VBox>
